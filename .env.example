# Supabase — copia estos valores desde tu proyecto en https://supabase.com/dashboard
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Supabase — Project Settings → API → "service_role" (secreta, NUNCA con
# prefijo NEXT_PUBLIC_). Solo la usa el cron de notificaciones push.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Notificaciones push (Web Push). Genera el par con:
#   npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Un mailto: o https:// de contacto — lo exige el estándar Web Push.
VAPID_SUBJECT=mailto:tu-correo@ejemplo.com

# Protege /api/cron/notify: Vercel la añade sola como header cuando
# despliegas con esta variable puesta y usas Vercel Cron.
CRON_SECRET=
