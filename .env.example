# Supabase — copia estos valores desde tu proyecto en https://supabase.com/dashboard
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Web Push (VAPID) — genera el par con: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-email@ejemplo.com

# Secreto para proteger el endpoint del cron de notificaciones.
# En Vercel, define CRON_SECRET y Vercel lo enviará automáticamente como
# "Authorization: Bearer <CRON_SECRET>" en las invocaciones del cron.
CRON_SECRET=un-secreto-largo-y-aleatorio

# Necesario para que el cron consulte los bloques de todos los usuarios
# (solo se usa en el servidor, NUNCA lo expongas con NEXT_PUBLIC_).
# Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=
